# ── Instagram / Meta Graph API ────────────────────────────────────────
# Long-lived access token (60 days) от Meta Developer Portal
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
# Instagram Business / Creator Account ID
INSTAGRAM_USER_ID=17841477136603889

# ── Agnes AI (генерация Reels видео) ─────────────────────────────────
AGNES_API_KEY=your_agnes_key_here

# ── Cloudinary (опционально — для image-постов) ──────────────────────
# Если не настроено, будут публиковаться только Reels
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# ── Pinterest (опционально) ──────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=

# ── Тайминги ─────────────────────────────────────────────────────────
# Задержка перед публикацией видео (сек) — дать Instagram время на обработку
VIDEO_PUBLISH_DELAY=30
