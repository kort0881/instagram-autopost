# ── Instagram / Meta Graph API ────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
INSTAGRAM_USER_ID=17841477136603889

# ── DeepSeek LLM (мозг системы — генерация hook, script, caption) ────
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Если ключ не задан — LLM работает в mock-режиме (шаблонный вывод)

# ── Agnes AI (генерация Reels видео) ─────────────────────────────────
AGNES_API_KEY=your_agnes_key_here

# ── Cloudinary (опционально — image-posts отключены по умолчанию) ────
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# ── Режимы ───────────────────────────────────────────────────────────
# PREPARE_ONLY=true — подготовить Reels-пакет, но не вызывать Agnes и Instagram
PREPARE_ONLY=false
# LLM_DISABLED=true — не вызывать DeepSeek, даже если ключ есть
LLM_DISABLED=false
# ENABLE_IMAGE_POSTS=true — включить image-посты (требует Cloudinary)
ENABLE_IMAGE_POSTS=false

# ── Тайминги ─────────────────────────────────────────────────────────
VIDEO_PUBLISH_DELAY=30

# ── Опционально ──────────────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=
